# LLM Backend: LlamaStack OpenAI-compatible endpoint (no API key required)
# Default model uses LlamaStack at the configured OPENAI_API_BASE
# SKILL_BUILDER_MODEL=openai/gemini/models/gemini-2.5-pro
# OPENAI_API_BASE=https://llamastack-llamastack.apps.ocp.v7hjl.sandbox2288.opentlc.com/v1

# Alternative: Direct Google Gemini API (requires GOOGLE_API_KEY)
# SKILL_BUILDER_MODEL=gemini-2.5-pro
# GOOGLE_API_KEY=your-key-here

# Optional: Server configuration (defaults shown)
# SKILL_BUILDER_HOST=0.0.0.0
# SKILL_BUILDER_PORT=8000
# SKILL_BUILDER_PROTOCOL=http
