# Required: Google API key for Gemini models
GOOGLE_API_KEY=your-key-here

# Optional: Override the default model (default: gemini-2.5-pro)
# Available Gemini models on LlamaStack:
#   gemini-2.5-pro (default, best reasoning/tool use)
#   gemini-2.5-flash (faster, lower cost)
#   gemini-2.0-flash (previous gen, fast)
# SKILL_BUILDER_MODEL=gemini-2.5-flash

# Optional: Server configuration (defaults shown)
# SKILL_BUILDER_HOST=0.0.0.0
# SKILL_BUILDER_PORT=8000
# SKILL_BUILDER_PROTOCOL=http
